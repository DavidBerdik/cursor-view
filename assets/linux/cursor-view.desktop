[Desktop Entry]
Type=Application
Version=1.0
Name=Cursor View
GenericName=Cursor Chat Viewer
Comment=View, search, and export your Cursor AI chat histories
# @EXEC@ is a placeholder substituted with the absolute path to the
# built cursor-view-desktop binary by assets/linux/install-linux.sh.
# --desktop launches the native webview UI rather than the browser flow.
Exec=@EXEC@ --desktop
Icon=cursor-view
Terminal=false
Categories=Development;Utility;
Keywords=cursor;chat;ai;history;export;
StartupWMClass=cursor-view-desktop
